.atp/work-session/
.claude/settings.local.json

# ---> 메신저봇R 클라이언트 로컬 사본 (내부 LAN IP/포트 포함, public 레포 보호)
# 템플릿은 *.template.js 로 커밋되며, 실값 치환본은 커밋 금지.
scripts/messenger-bot/remote-kakao.js

# ---> PII history rewrite 안전망 (2026-05-16 세션의 raw .git 사본).
# 사용자가 며칠 확인 후 수동으로 rm -rf 예정. 절대 커밋 금지.
.git.backup-pre-pii/

