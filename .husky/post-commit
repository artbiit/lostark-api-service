#!/bin/sh
# graphify multi-scope post-commit hook (lostark-remote-kakao)
#
# 본 레포는 docs/graph/{packages,docs,tests,legacy}/ 4 scope 분할 구조.
# graphify CLI 의 기본 hook 은 graphify-out/ 단일 graph 가정이라 mismatch.
# 이 wrapper 는:
#   1. git diff 로 변경 파일의 scope 판정 (packages / tests / legacy)
#   2. docs/graph/<scope>/ 를 graphify-out/ 으로 stage (incremental --update 용 cache)
#   3. graphify <scope> --update 실행 (AST-only, ~수초)
#   4. graphify-out/ → docs/graph/<scope>/ 로 sync back
#   5. graphify-out/ 정리
#
# docs/* 변경은 skip — LLM semantic 필요, 본 세션 inline /graphify 또는 background subagent 로 처리.
# 정책: agent-team-protocol §9.1 (이월 금지). MEMORY: feedback_graphify_no_defer_policy.

# Skip during rebase/merge/cherry-pick (저장 안된 변경 차단 회피)
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)
[ -d "$GIT_DIR/rebase-merge" ] && exit 0
[ -d "$GIT_DIR/rebase-apply" ] && exit 0
[ -f "$GIT_DIR/MERGE_HEAD" ] && exit 0
[ -f "$GIT_DIR/CHERRY_PICK_HEAD" ] && exit 0

CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || git diff --name-only HEAD 2>/dev/null)
[ -z "$CHANGED" ] && exit 0

# Detect affected code scopes (docs/* 는 hook 스킵, LLM 필요)
SCOPES=""
for f in $CHANGED; do
    case "$f" in
        packages/*) echo "$SCOPES" | grep -qw packages || SCOPES="$SCOPES packages" ;;
        tests/*)    echo "$SCOPES" | grep -qw tests    || SCOPES="$SCOPES tests"    ;;
        legacy/*)   echo "$SCOPES" | grep -qw legacy   || SCOPES="$SCOPES legacy"   ;;
    esac
done

[ -z "$SCOPES" ] && exit 0

REPO_ROOT=$(git rev-parse --show-toplevel)
LOG="$HOME/.cache/graphify-rebuild.log"
mkdir -p "$(dirname "$LOG")"

# Run rebuild in background — git commit 자체 차단 안 함
(
    cd "$REPO_ROOT" || exit 1
    {
        echo "[graphify hook $(date -u +%FT%TZ)] commit=$(git rev-parse --short HEAD) scopes=$SCOPES"

        for scope in $SCOPES; do
            SCOPE_DIR="docs/graph/$scope"
            if [ ! -d "$SCOPE_DIR" ]; then
                echo "[graphify hook] $SCOPE_DIR missing — skip"
                continue
            fi

            # Stage prior outputs for incremental --update
            rm -rf graphify-out
            cp -R "$SCOPE_DIR" graphify-out

            # AST-only update on this scope
            if graphify "$scope" --update --no-viz >/dev/null 2>&1; then
                rsync -a --delete --exclude='.gitkeep' graphify-out/ "$SCOPE_DIR/"
                echo "[graphify hook] $scope: updated"
            else
                echo "[graphify hook] $scope: rebuild FAILED — try manually"
            fi
        done

        rm -rf graphify-out
        echo "[graphify hook] done"
    } >> "$LOG" 2>&1
) </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true
exit 0
