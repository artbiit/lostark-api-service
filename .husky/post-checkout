#!/bin/sh
# graphify multi-scope post-checkout hook (lostark-remote-kakao)
# Branch 전환 시 변경된 scope 의 graph 를 재생성. post-commit 과 동일 multi-scope wrapper.

PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_SWITCH=$3

# Only run on branch switches, not file checkouts
[ "$BRANCH_SWITCH" = "1" ] || exit 0
[ -z "$PREV_HEAD" ] || [ -z "$NEW_HEAD" ] && exit 0
[ "$PREV_HEAD" = "$NEW_HEAD" ] && exit 0

CHANGED=$(git diff --name-only "$PREV_HEAD" "$NEW_HEAD" 2>/dev/null)
[ -z "$CHANGED" ] && exit 0

SCOPES=""
for f in $CHANGED; do
    case "$f" in
        packages/*) echo "$SCOPES" | grep -qw packages || SCOPES="$SCOPES packages" ;;
        tests/*)    echo "$SCOPES" | grep -qw tests    || SCOPES="$SCOPES tests"    ;;
        legacy/*)   echo "$SCOPES" | grep -qw legacy   || SCOPES="$SCOPES legacy"   ;;
    esac
done

[ -z "$SCOPES" ] && exit 0

REPO_ROOT=$(git rev-parse --show-toplevel)
LOG="$HOME/.cache/graphify-rebuild.log"
mkdir -p "$(dirname "$LOG")"

(
    cd "$REPO_ROOT" || exit 1
    {
        echo "[graphify checkout $(date -u +%FT%TZ)] $PREV_HEAD..$NEW_HEAD scopes=$SCOPES"

        for scope in $SCOPES; do
            SCOPE_DIR="docs/graph/$scope"
            [ -d "$SCOPE_DIR" ] || { echo "[graphify hook] $SCOPE_DIR missing — skip"; continue; }

            rm -rf graphify-out
            cp -R "$SCOPE_DIR" graphify-out

            if graphify "$scope" --update --no-viz >/dev/null 2>&1; then
                rsync -a --delete --exclude='.gitkeep' graphify-out/ "$SCOPE_DIR/"
                echo "[graphify hook] $scope: updated"
            else
                echo "[graphify hook] $scope: rebuild FAILED"
            fi
        done

        rm -rf graphify-out
        echo "[graphify hook] done"
    } >> "$LOG" 2>&1
) </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true
exit 0
